{
  "name": "@casola/avatar-client",
  "version": "0.1.2",
  "description": "Browser SDK for Casola live avatar sessions (MSE video + mic streaming).",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worklet": "./dist/worklet/mic-worklet.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/casola-ai/avatar-client.git"
  },
  "homepage": "https://github.com/casola-ai/avatar-client#readme",
  "bugs": {
    "url": "https://github.com/casola-ai/avatar-client/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build.mjs && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.3.3",
    "vitest": "~3.2.0"
  }
}
